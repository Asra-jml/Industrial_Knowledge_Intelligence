# Copy to .env and fill in. Everything is optional — the pipeline degrades
# gracefully (no Neo4j -> graph.json only; no Groq -> LLM enrichment skipped;
# no Tesseract -> scanned PDFs marked readable:false).

# --- Paths (defaults work when this repo sits next to SharedCorpus) ---
CORPUS_ROOT=../SharedCorpus
# SHARED_DIR defaults to <CORPUS_ROOT>/shared
SHARED_DIR=

# --- Neo4j Aura Free (create at https://console.neo4j.io) ---
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- LLM enrichment (either provider; both are OpenAI-compatible) ---
# xAI Grok key (starts xai-...) from https://console.x.ai
GROK_API_KEY=
# OR Groq key (starts gsk_...) from https://console.groq.com — used if set
GROQ_API_KEY=
# optional explicit model override (defaults picked per provider)
LLM_MODEL=

# --- OCR: only set if tesseract.exe is not on PATH ---
TESSERACT_CMD=

# --- P&ID CV ---
PID_OCR_SAMPLE=3
